              </items>
              <chunks count="1">
                <chunk name="Container">
                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""Cretes a resource which can be added to a Klimatdatabas json object
    Inputs:
        name: string representing the name of the resource
        category: string representing the Klimatdatabas category of the resource
        general_comment: string representing a comment for the resource
        inventory_unit: unit used for the inventory, if unset defaults to "kg"
        volume_conversion: density of the material in kg/m3
        gwp_a1_a3_conservative: global warming potential, module A1-A3 (conservative value)
        gwp_a1_a3_typical: global warming potential, module A1-A3 (typical value)
        gwp_a4: global warming potential, module A4
        gwp_a5_1: global warming potential, module A5.1
        addtl_data: tree with two branches, the first a list of strings representing data points to add, the secondly with the corresponding values to add/replace
    Output:
        resource: dictionary representing resource"""

import scriptcontext
import ghpythonlib.treehelpers as th
import brimstone
from datetime import datetime
reload(brimstone)

ghenv.Component.Message = brimstone.globals.version
ghenv.Component.Name = 'Brimstone - Create Klimatdatabas resource'
ghenv.Component.NickName = 'Create Klimatdatabas resource'

def main(data, addtl_data):
    resource =  {        
        "ResourceId": 6000000000,
        "SourceVersion": "",
        "ProductSystemId": -1,
        "ProductSystemResourceId": "",
        "Location": "SE",
        "Publisher": "Boverket, Sweden",
        "Version": "",
        "Copyright": False,
        "TimeStamp": datetime.now().isoformat(),
        "Name": data["name"],
        "Names": {
          "EN": data["name"],
          "SV": data["name"]
        },
        "StdName": "",
        "StdDescription": "",
        "StdCalc": "",
        "UseAdviceForDataSet": "",
        "TechnologicalApplicability": "",
        "GeneralComment": data["general_comment"],
        "Synonyms": "",
        "TechnologyDescriptionAndIncludedProcesses": "",
        "GeographicalRepresentativenessDescription": "",
        "TimeRepresentativenessDescription": "",
        "UpdatedTime": datetime.now().isoformat(),
        "InventoryUnit": data["inventory_unit"],
        "CalculatedBiogenicCarbon": None,
        "ConservativeDataConversionFactor": None,
        "WasteFactor": None,
        "RefServiceLifeNormal": "",
        "RefServiceLifeNormalComment": "",
        "ComparativeProperty": "",
        "A4ValueBackground": "",
        "AnnualSupplyOrProductionVolume": "",
        "Conversions": [{
          "Field": "Volume",
          "Unit": "kg/m³",
          "Value": data["volume_conversion"]
        }],
        "DataItems": [{
          "PropertyId": 1845,
          "PropertyName": "Global Warming potential",
          "PropertyCode": "GWP-GHG AR4",
          "PropertyTypeId": 2,
          "PropertyUnitCode": "kg CO2 eq./kg",
          "DataValueItems": [{
            "DataModuleCode": "A1-A3 Conservative",
            "Value": data["gwp_a1_a3_conservative"]
          }, {
            "DataModuleCode": "A1-A3 Typical",
            "Value": data["gwp_a1_a3_typical"]
          }, {
            "DataModuleCode": "A4",
            "Value": data["gwp_a4"]
          }, {
            "DataModuleCode": "A5.1",
            "Value": data["gwp_a5_1"]
          }]
        }],
        "Categories": [{
          "ClassificationType": "Boverket",
          "Text": data["category"]
        }]
    }
    
    if addtl_data.BranchCount:
        addtl_data_list = th.tree_to_list(addtl_data, None)
        print addtl_data_list
        data_keys = addtl_data_list[0]
        data_vals = addtl_data_list[1]
        if not len(data_keys) == len(data_vals):
            brimstone.utils.warn(ghenv, "The number if additional data keys and data values must be the same")
        elif not len(data_keys) == len(set(data_keys)):
            brimstone.utils.warn(ghenv, "The additional data keys must be unique")
        else:
            for i, key in enumerate(data_keys):
                resource[str(key)] = str(data_vals[i])
    
    print resource
    return resource

if __name__ == "__main__":
    if not scriptcontext.sticky["brimstone_flying"]:
        raise Exception("The 'Brimstone - Fly' component needs to exist on the canvas")
    
    replace_null = brimstone.utils().replace_null
    
    data = {
        "name": replace_null(name, ""),
        "category": replace_null(category, ""),
        "general_comment": replace_null(general_comment, ""),
        "inventory_unit": replace_null(inventory_unit, "kg"),
        "volume_conversion": replace_null(volume_conversion, 0),
        "gwp_a1_a3_conservative": replace_null(gwp_a1_a3_conservative, 0),
        "gwp_a1_a3_typical": replace_null(gwp_a1_a3_typical, 0),
        "gwp_a4": replace_null(gwp_a4, 0),
        "gwp_a5_1": replace_null(gwp_a5_1, 0),
    }
    
    resource = main(data, addtl_data)
    resource = [resource]

