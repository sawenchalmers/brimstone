            <chunk name="Object" index="111">
              <items count="3">
                <item name="GUID" type_name="gh_guid" type_code="9">410755b1-224a-4c1e-a407-bf32fb45ea7e</item>
                <item name="Lib" type_name="gh_guid" type_code="9">00000000-0000-0000-0000-000000000000</item>
                <item name="Name" type_name="gh_string" type_code="10">Brimstone - Add Life Cycle Info to Honeybee Construction</item>
              </items>
              <chunks count="1">
                <chunk name="Container">
                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""
Adds GWP info to a Honeybee Construction

    Args:
        hb_construction: Honeybee Construction to be updated
        gwp_a1_a3: GWP (A1-A3) [kg CO2eq/kg]
        gwp_a4: GWP (A4) [kg CO2eq/kg]
        density: density [kg/m2]

    Returns:
        mod_construction: Updated Honeybee Construction
"""

import scriptcontext
import brimstone
ghenv.Component.Message = brimstone.globals.version
import Grasshopper

ghenv.Component.Name = 'Brimstone - Add Life Cycle Info to Honeybee Construction'
ghenv.Component.NickName = 'Add Life Cycle Info (Construction)'

try:  # import the core honeybee dependencies
    from honeybee_energy.construction.window import WindowConstruction
    from honeybee_energy.construction.opaque import OpaqueConstruction
except ImportError as e:
    raise ImportError('\nFailed to import honeybee:\n\t{}'.format(e))

def main(hb_construction, gwp_a1_a3, gwp_a4, density):
    if not isinstance(hb_construction, WindowConstruction)\
        and not isinstance(hb_construction, OpaqueConstruction):
        raise Exception("Currently only Window and Opaque constructions are supported")
    mod_construction = hb_construction.duplicate()
    user_data = mod_construction.user_data if mod_construction.user_data else {}
    
    if gwp_a1_a3 is not None:
        user_data["gwp_a1_a3"] = gwp_a1_a3
    if gwp_a4 is not None:
        user_data["gwp_a4"] = gwp_a4
    if density is not None:
        user_data["conv_value"] = density
    
    mod_construction.user_data = user_data

    return mod_construction

if __name__ == "__main__":
    try:
        flying = scriptcontext.sticky["brimstone_flying"]
    except:
        raise Exception("The 'Brimstone - Fly' component needs to exist on the canvas")
    mod_construction = main(hb_construction, gwp_a1_a3, gwp_a4, density)
