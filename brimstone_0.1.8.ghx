            <chunk name="Object" index="39">
              <items count="3">
                <item name="GUID" type_name="gh_guid" type_code="9">410755b1-224a-4c1e-a407-bf32fb45ea7e</item>
                <item name="Lib" type_name="gh_guid" type_code="9">00000000-0000-0000-0000-000000000000</item>
                <item name="Name" type_name="gh_string" type_code="10">Brimstone - Add Life Cycle Info to Honeybee Material</item>
              </items>
              <chunks count="1">
                <chunk name="Container">
                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""
Adds GWP info to a Honeybee Material

    Args:
        hb_material: Honeybee EnergyMaterial to be updated
        gwp_a1_a3: GWP (A1-A3) [kg CO2eq/kg]
        gwp_a4: GWP (A4) [kg CO2eq/kg]
        gwp_a5_1: GWP (A5.1) [kg CO2eq/kg]

    Returns:
        mod_material: Updated Honeybee EnergyMaterial
"""

import scriptcontext
import brimstone
ghenv.Component.Message = brimstone.globals.version
import Grasshopper

ghenv.Component.Name = 'Brimstone - Add Life Cycle Info to Honeybee Material'
ghenv.Component.NickName = 'Add Life Cycle Info'

try:  # import the core honeybee dependencies
    from honeybee_energy.material.opaque import EnergyMaterial
except ImportError as e:
    raise ImportError('\nFailed to import honeybee:\n\t{}'.format(e))

def main(hb_material):
    if not isinstance(hb_material, EnergyMaterial):
        raise Exception("Input material must be a valid Honeybee material")
    mod_material = hb_material.duplicate()
    user_data = mod_material.user_data if mod_material.user_data else {}
    
    impact_data = {
        "gwp_a1_a3": gwp_a1_a3,
        "gwp_a4": gwp_a4,
        "gwp_a5": gwp_a5_1,
        "gwp_c1": gwp_c1,
        "gwp_c2": gwp_c2,
        "gwp_c3": gwp_c3,
    }
    
    for k, v in impact_data.items():
        if v is not None:
            user_data[k] = v

    mod_material.user_data = user_data
    
    return mod_material

if __name__ == "__main__":
    try:
        flying = scriptcontext.sticky["brimstone_flying"]
    except:
        raise Exception("The 'Brimstone - Fly' component needs to exist on the canvas")
    mod_material = main(hb_material)    
