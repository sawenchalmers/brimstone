            <chunk name="Object" index="65">
              <items count="3">
                <item name="GUID" type_name="gh_guid" type_code="9">410755b1-224a-4c1e-a407-bf32fb45ea7e</item>
                <item name="Lib" type_name="gh_guid" type_code="9">00000000-0000-0000-0000-000000000000</item>
                <item name="Name" type_name="gh_string" type_code="10">Brimstone - Calculate Embodied Carbon of Honeybee Model</item>
              </items>
              <chunks count="1">
                <chunk name="Container">
                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""
Calculates embodied carbon for the elements of a Honeybee model if data is available
This component was inspired by the 'HB Color Face Attributes' component of Ladybug Tools 1.6.0

    Args:
        hb_model: Honeybee model for analysis
        kdb_json_data: Optional json data object for materials which do not include impact data

    Returns:
        tot_emb_carbon: total embodied carbon of model
        elements: element types in the model
        el_emb_carbon: embodied carbon for each element type in the model
"""

import scriptcontext
import brimstone
ghenv.Component.Message = brimstone.globals.version
import Grasshopper
import os
import csv, codecs

ghenv.Component.Name = 'Brimstone - Calculate Embodied Carbon of Honeybee Model'
ghenv.Component.NickName = 'Calculate Honeybee Model'

try:  # import the core honeybee dependencies
    from honeybee_energy.construction.windowshade import WindowConstructionShade
    from honeybee_energy.construction.air import AirBoundaryConstruction
    from honeybee_energy.material.opaque import EnergyMaterialNoMass
    from honeybee.model import Model
    from honeybee.properties import FaceProperties
    from honeybee.typing import clean_ep_string
except ImportError as e:
    raise ImportError('\nFailed to import honeybee:\n\t{}'.format(e))
    

# todo: magic string here - not good!
gwp_data_string = "Global Warming potential"
gwp_data_points = {
    "gwp_a1_a3": "A1-A3 Conservative",
    "gwp_a4": "A4",
    "gwp_a5_1": "A5.1",
    "gwp_c1": "C1",
    "gwp_c2": "C2",
    "gwp_c3": "C3",
} 

def main(hb_model):
    tot_emb_carbon = 0
    elements = []
    el_emb_carbon = []
    elements_modules = []
    el_emb_carbon_modules = []
    if not isinstance(hb_model, Model):
        raise Exception("hb_model input must be a valid honeybee model")
    faces = []
    apertures = []
    model_mats = {}
    face_types = {}
    
    energy_properties = hb_model.properties.energy
    
    for material in energy_properties.materials:
        model_mats[material.identifier] = {
            "material": material,
            "amount": 0.0,
        }
    for room in hb_model.rooms:
        faces.extend(room.faces)
        faces.extend(room.shades)
    faces.extend(hb_model.orphaned_faces)
    faces.extend(hb_model.orphaned_apertures)
    faces.extend(hb_model.orphaned_doors)
    faces.extend(hb_model.orphaned_shades)
    
    for face_obj in faces:
        print face_obj
        if isinstance(face_obj.properties, FaceProperties):
            if isinstance(face_obj.properties.energy.construction, AirBoundaryConstruction):
                continue # skip if airboundary
                
            face_area = face_obj.area - face_obj.aperture_area
            face_type = face_obj.type
            
            face_impact = {}
            for lyr in face_obj.properties.energy.construction.layers:
                if lyr not in model_mats:
                    brimstone.utils.warn(ghenv, "Calculation may be faulty as material " + lyr + " does not exist in model.")
                else:
                    model_mats[lyr]["amount"] += face_area*model_mats[lyr]["material"].thickness
                face_impact_per_module = get_face_impact([mat["material"] for mat in model_mats.values()], lyr, face_area)
                for key in face_impact_per_module:
                    if key in face_impact:
                        face_impact[key] += face_impact_per_module[key]
                    else:
                         face_impact[key] = face_impact_per_module[key]
                """
                if lyr not in model_mats.keys():
                    model_mats[lyr] = { area: face_area }
                else:
                    model_mats[lyr].area = model_mats[lyr].area + face_area
                """
                       
            if face_type not in face_types:
                face_types[face_type] = { "impact": face_impact }
            else:
                for key in face_impact:
                    if key in face_types[face_type]["impact"]:
                        face_types[face_type]["impact"][key] += face_impact[key]
                    else:
                        face_types[face_type]["impact"][key] = face_impact[key]
                
            
            for aperture in face_obj.apertures:
                aperture_impact = get_aperture_impact(aperture)
                if "Aperture" not in face_types:
                    face_types["Aperture"] = { "impact": aperture_impact }
                else:
                    for key in aperture_impact:
                        if key in face_types["Aperture"]["impact"]:
                            face_types["Aperture"]["impact"][key] += aperture_impact[key]
                        else:
                            face_types["Aperture"]["impact"][key] = aperture_impact[key]
                        
    for face_type in face_types.items():
        face_impact = sum(face_type[1]["impact"].values())
        tot_emb_carbon += face_impact
        elements.append(face_type[0])
        el_emb_carbon.append(face_impact)
        
        for key, value in face_type[1]["impact"].items():
            elements_modules.append(str(face_type[0]) + " " + key)
            el_emb_carbon_modules.append(value)
    return tot_emb_carbon, elements, el_emb_carbon, elements_modules, el_emb_carbon_modules, model_mats.keys(), [mat["amount"] for mat in model_mats.values()]

def get_face_impact(materials, layer_name, face_area):
    for material in materials:
        if material.identifier == layer_name:
            if type(material) == EnergyMaterialNoMass:
                brimstone.utils.warn(ghenv, "The calculation may be faulty as material " + layer_name + " is modelled as EnergyMaterialNoMass.")
                return {}
            abs_impact = {}
            gwp_data_keys = gwp_data_points.keys()
            if material.user_data:
                for key, value in gwp_data_points.items():
                    if key in material.user_data:
                        abs_impact[value] = material.density*material.user_data[key]
            else:
                abs_impact = get_face_impact_from_material_name(material.identifier, material.density)
            impact = { key: material.thickness*abs_impact[key]*face_area for key in abs_impact }
            return impact
    brimstone.utils.warn(ghenv, "The calculation may be faulty as material " + layer_name + " was not found among the energy materials in the model.")
    return {}

# Gets material impact data from a honeybee material by referencing names in .csv file
def get_face_impact_from_material_name(material_name, density):
    csv_data_file = brimstone.globals.hb_kdb_csv_path
    csv_data_file_path = os.path.join(Grasshopper.Folders.UserObjectFolders[0], csv_data_file)
    if not os.path.exists(csv_data_file_path):
        raise Exception("Failed to open csv file, it should reside in [UserComponents folder]/brimstone_data/")
    kdb_name = check_name_in_kdb(material_name)
    if not kdb_name:
        with open(csv_data_file_path, 'r') as csv_file:
            file_reader = csv.DictReader(csv_file, delimiter=",")
            for row in file_reader:
                if row["HB Name"] == material_name:
                    kdb_name = clean_ep_string(row["Klimatdatabas name"])
                    if not kdb_name or kdb_name == "missing":
                        brimstone.utils.warn(ghenv, "The calculation may be faulty as impact data is missing for some of the materials in the model: " + material_name)
                        return {}
                    break
    if not kdb_name:
        brimstone.utils.warn(ghenv, "The calculation may be faulty as material " + material_name + " could not be matched to any material in the brimstone material database.")
        return {}
    
    return get_impact_from_json_data(kdb_name, density)

def check_name_in_kdb(material_name):
    if not kdb_json_data:
        brimstone.utils.warn(ghenv, "The calculation may be faulty as kdb_json_data is missing")
    else: 
        for resource in kdb_json_data["Resources"]:
            if clean_ep_string(resource["Name"]) == material_name:
                return material_name
    return ""
    
# TODO: currently only works for KDB windows
def get_aperture_impact(aperture):
    c = aperture.properties.energy.construction
    c = c.window_construction if type(c) == WindowConstructionShade else c
    if c.user_data and "conv_value" in c.user_data:
        impact = {}
        density = c.user_data["conv_value"] # kg/m2
        for key, value in gwp_data_points.items():
            if key in c.user_data:
                impact[value] = float(c.user_data[key]) * density * aperture.area
        return impact
    if not len(c.layers) == 1:
        brimstone.utils.warn(ghenv, "The calculation may be faulty as only one layer window constructions can be calculated.")
        return {}
    
    window_material = c.layers[0]
    abs_impact = get_impact_from_json_data(window_material)
    impact = { key: abs_impact[key]*aperture.area for key in abs_impact }
    return impact

# density parameter is used as fallback if KDB data does not have density
def get_impact_from_json_data(kdb_name, density = 0):
    if not kdb_json_data:
        brimstone.utils.warn(ghenv, "The calculation may be faulty as kdb_json_data is missing")
        return {}
    for resource in kdb_json_data["Resources"]:
        if clean_ep_string(resource["Name"]) == kdb_name:
            if "Conversions" not in resource:
                brimstone.utils.warn(ghenv, "The calculation may be faulty as material " + kdb_name + " has no conversion value in kdb_json_data. Using HB material density")
                conv = density
            else:
                conv = resource["Conversions"][0]["Value"]
            
            for data_item in resource["DataItems"]:
                if data_item["PropertyName"] == gwp_data_string:
                    abs_impact = {}
                    for data_pt in gwp_data_points.values():
                        for data_val_item in data_item["DataValueItems"]:
                            if data_val_item["DataModuleCode"] == data_pt:
                                abs_impact[data_pt] = data_val_item["Value"]*conv
                                break
                    return abs_impact
            brimstone.utils.warn(ghenv, "The calculation may be faulty as material " + kdb_name + " has no GWP data in kdb_json_data")
            return {}
    brimstone.utils.warn(ghenv, "The calculation may be faulty as material " + kdb_name + " was not found in kdb_json_data")
    return {}

if __name__ == "__main__":
    try:
        flying = scriptcontext.sticky["brimstone_flying"]
    except:
        raise Exception("The 'Brimstone - Fly' component needs to exist on the canvas")
    tot_emb_carbon, elements, el_emb_carbon, elements_modules, el_emb_carbon_modules, materials, material_amounts = main(hb_model)</item>
