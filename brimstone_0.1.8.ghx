                <item name="Lib" type_name="gh_guid" type_code="9">00000000-0000-0000-0000-000000000000</item>
                <item name="Name" type_name="gh_string" type_code="10">Brimstone - Add resource to Klimatdatabas data</item>
              </items>
              <chunks count="1">
                <chunk name="Container">
                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""Adds a resource to a Klimatdatabas json object
    Inputs:
        json_data: dictionary with json data
        resource: dictionary representing the resource data
    Output:
        json_data: updated dictionary with json data"""

import scriptcontext
import brimstone
ghenv.Component.Message = brimstone.globals.version
import copy

ghenv.Component.Name = 'Brimstone - Add resource to Klimatdatabas data'
ghenv.Component.NickName = 'Add resource to Klimatdatabas'

def main(json_data, resource):
    print resource
    resource_cat = resource["Categories"][0]["Text"]
    pred = lambda v: v["Title"] == resource_cat
    if not filter(pred, json_data["Categories"][0]["Children"]):
        raise Exception("Could not add resource to database as the indicated category does not exist in the database.")
    json_data["Resources"].append(resource)
    return json_data

if __name__ == "__main__":
    if not scriptcontext.sticky["brimstone_flying"]:
        raise Exception("The 'Brimstone - Fly' component needs to exist on the canvas")
    json_data = main(copy.deepcopy(json_data), resource)
    json_data = [json_data]

