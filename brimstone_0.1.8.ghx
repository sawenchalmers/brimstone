                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""This component sets up global information for Brimstone
    Inputs:
    Output:
        """

import Grasshopper
import sys, os
root = Grasshopper.Folders.UserObjectFolders[0]

# Allow both root and /Brimstone subfolder
candidates = [
    root,
    os.path.join(root, "Brimstone"),
    os.path.join(root, "brimstone")
]

for path in candidates:
    if os.path.isdir(path) and path not in sys.path:
        sys.path.append(path)
        

import brimstone
reload(brimstone)

import scriptcontext

ghenv.Component.Name = 'Brimstone - Fly!'
ghenv.Component.NickName = 'Fly!'

scriptcontext.sticky["brimstone_flying"] = 'true'
ghenv.Component.Message = brimstone.globals.version</item>
