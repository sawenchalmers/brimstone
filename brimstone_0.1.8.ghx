                  <items count="12">
                    <item name="CodeInput" type_name="gh_string" type_code="10">import ghpythonlib.treehelpers as th
lca_data = th.tree_to_list(lca_data)[0]

lca_data = dict(zip(lca_data[0], lca_data[1]))
print lca_data
gwp_a1_a3 = lca_data["GWPA1A3Conservative"]
gwp_a4 = lca_data["GWPA4"]
density = lca_data["ConversionValue"]
</item>
