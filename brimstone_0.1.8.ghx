                <chunk name="Container">
                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""Gets Klimatdatabas from the Boverket API or a file, extracts json data, and resource category names
    Inputs:
        mode: api or file mode
        language: language of database to retrieve
        json_path: path to json file if file mode
    Output:
        json_data: json file as dictionary
        categories: Categories present in the database
        klimatdatabas_version: String representing the version of Klimatdatabas used"""

import scriptcontext
import brimstone
import Grasshopper
import os, io

ghenv.Component.Name = 'Brimstone - Get Categories'
ghenv.Component.NickName = 'Get Categories'
ver = brimstone.globals.version
ghenv.Component.Message = ver

import json

from System.Net import WebRequest
from System.IO import StreamReader
from System.Text import Encoding

def main(mode):    
    if mode == "file":
        json_file = brimstone.globals.kdb_json_path
        json_path = os.path.join(Grasshopper.Folders.UserObjectFolders[0], json_file)
        if not os.path.exists(json_path):
            raise Exception("Failed to open json file, it should reside in [UserComponents folder]/brimstone_data/")
        json_data = get_json_data_from_file(json_path)
    elif mode == "api":
        json_data = get_json_data_from_api()
    else:
        raise Exception("Mode {mode} not supported".format(mode = mode))
    
    categories = get_categories(json_data)
    version = json_data.get("Version") 
    
    return categories, json_data, version

def get_json_data_from_file(json_path):
    f = io.open(json_path, encoding='utf-8')
    json_data = json.load(f)
    return json_data
    
def get_json_data_from_api():
    version = "02.06.000"
    lng = language if language else "en"
    format = "json"

    url = "https://api.boverket.se/klimatdatabas/v2/get-all-resources/{version}/{language}/{format}".format(
        version=version, language=lng, format=format)
    
    request = WebRequest.Create(url)
    
    request.Method = "GET"
    request.Timeout = 5000
    #request.ContentType = "application/json"
    response = request.GetResponse()
    
    stream_reader = StreamReader(response.GetResponseStream())
    json_data = json.loads(stream_reader.ReadToEnd())
    return json_data
    
def get_categories(json_data):
    categories = []
    try:
        for metaCategory in json_data['Categories']:
            for cat in metaCategory["Children"]:
                categories.append(cat["Title"])
    except KeyError:
        raise Exception("Format of JSON data is not supported.")
    return categories

if __name__ == "__main__":
    if not scriptcontext.sticky["brimstone_flying"]:
        raise Exception("The 'Brimstone - Fly' component needs to exist on the canvas")
    categories, json_data, klimatdatabas_version = main(mode)
    json_data = [json_data] # need to put it in an array so GH understands it as a dictionary
    
    

