                <item name="GUID" type_name="gh_guid" type_code="9">410755b1-224a-4c1e-a407-bf32fb45ea7e</item>
                <item name="Lib" type_name="gh_guid" type_code="9">00000000-0000-0000-0000-000000000000</item>
                <item name="Name" type_name="gh_string" type_code="10">Brimstone - Get LCA Data</item>
              </items>
              <chunks count="1">
                <chunk name="Container">
                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""Extracts LCA indicators and values from a Klimatdatabas json for a specific resource
    Inputs:
        json_data: dictionary with json data
        resources: list of readable names of resources
        addtl_indicators: list of additional keys to retrieve from resource
    Output:
        lca_data: list of dictionaries with LCA data for each resource
        indicators: list of indicators
        values: list of indicator values"""

import scriptcontext
import ghpythonlib.treehelpers as th
from collections import OrderedDict
import copy

import brimstone
ghenv.Component.Message = brimstone.globals.version

ghenv.Component.Name = 'Brimstone - Get LCA Data'
ghenv.Component.NickName = 'Get LCA Data'

# todo: magic string here - not good!
gwp_data_string = "Global Warming potential"

# keys: names in output dict, values: DataModuleCode in json db
gwp_data_entries = {
    "GWPA1A3Conservative": "A1-A3 Conservative",
    "GWPA1A3Typical": "A1-A3 Typical",
    "GWPA4": "A4",
    "GWPA5.1": "A5.1",
}

def main(json_data, resource, addtl_indicators):
    lca_data, indicators, values = [], [], []

    for i, resource in enumerate(resources):
        lca_data.append(get_lca_data(json_data, resource, addtl_indicators))
        resource_indicators, resource_values = get_indicator_values(lca_data[i], addtl_indicators)
        indicators.append(resource_indicators)
        values.append(resource_values)
    return lca_data, indicators, values
    
def get_lca_data(json_data, resource_name, addtl_indicators):
    resource_data = copy.deepcopy(
        find_obj_in_array(
            json_data["Resources"],
            "Name",
            resource_name
        )
    )
    
    if not resource_data:
        raise Exception(
            "Resource with name {resource_name} was not found in database."
            .format(resource_name = resource_name)
       )
    try:
        lca_data = extract_lca_data(resource_data, addtl_indicators)
    except KeyError:
        raise Exception("Format of JSON data is not supported.")
    return lca_data

def extract_lca_data(resource_data, addtl_indicators):
    lca_data = OrderedDict()
    resource_name = resource_data["Name"]
    
    lca_data["Name"] = resource_name
    
    if "Conversions" in resource_data:
        # can a resource have multiple conversions?
        lca_data["ConversionUnit"] = resource_data["Conversions"][0]["Unit"]
        lca_data["ConversionValue"] = resource_data["Conversions"][0]["Value"]
    
    if "InventoryUnit" in resource_data:
        lca_data["InventoryUnit"] = resource_data["InventoryUnit"]
    
    for data_prop in resource_data["DataItems"]:
        if data_prop["PropertyName"] == gwp_data_string:
            gwp_data = copy.deepcopy(data_prop)
            break
            
    if not gwp_data:
        raise Exception("GWP data not found for {resource_name}"
            .format(resource_name = resource_name))
    
    lca_data["GWPUnit"] = gwp_data["PropertyUnitCode"]
    for key in gwp_data_entries:
        value = find_obj_in_array(
            gwp_data["DataValueItems"],
            "DataModuleCode",
            gwp_data_entries[key]
        )
        if value is not None:
            lca_data[key] = value["Value"]
            
    for addtl_indicator in addtl_indicators:
        if addtl_indicator in resource_data:
            lca_data[addtl_indicator] = resource_data[addtl_indicator]
    
    return lca_data

def find_obj_in_array(array, key, value):
    return next((x for x in array if x[key] == value), None)

def get_indicator_values(lca_data, addtl_indicators):
    indicator_dict = OrderedDict([
        ("Name", "Name"),
        ("InventoryUnit", "Inventory unit"),
        ("ConversionUnit", "Conversion unit"),
        ("ConversionValue", "Conversion value"),
        ("GWPUnit", "GWP unit"),
        ("GWPA1A3Conservative", "GWP (A1-A3 Conservative)"),
        ("GWPA1A3Typical", "GWP (A1-A3 Typical)"),
        ("GWPA4", "GWP (A4)"),
        ("GWPA5.1", "GWP (A5.1)"),
    ])
    
    for addtl_indicator in addtl_indicators:
        indicator_dict[addtl_indicator] = addtl_indicator
    
    indicators, values = [], []
    
    for key, indicator_name in indicator_dict.items():
        indicator_value = lca_data[key] if key in lca_data else None
        if indicator_value:
            indicators.append(indicator_name)
            values.append(indicator_value)
    
    return indicators, values

if __name__ == "__main__":
    if not scriptcontext.sticky["brimstone_flying"]:
        raise Exception("The 'Brimstone - Fly' component needs to exist on the canvas")
    lca_data, indicators, values = main(json_data, resources, addtl_indicators)
    
    lca_data_treeable = []
    
    for resource_lca_data in lca_data:
        lca_data_treeable.append([resource_lca_data.keys(), resource_lca_data.values()])
    lca_data = th.list_to_tree(lca_data_treeable)
    indicators = th.list_to_tree(indicators)
    values = th.list_to_tree(values)
    json_data = [json_data]

