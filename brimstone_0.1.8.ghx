            <chunk name="Object" index="59">
              <items count="3">
                <item name="GUID" type_name="gh_guid" type_code="9">410755b1-224a-4c1e-a407-bf32fb45ea7e</item>
                <item name="Lib" type_name="gh_guid" type_code="9">00000000-0000-0000-0000-000000000000</item>
                <item name="Name" type_name="gh_string" type_code="10">Brimstone - Honeybee Construction from Klimatdatabas materials</item>
              </items>
              <chunks count="1">
                <chunk name="Container">
                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10"># Inspired by HB Opaque Material/HB Window Construction from Ladybug Tools 1.6.0

"""
Creates a Honeybee Construction from a list of Klimatdatabas material names

    Args:
        construction_name: Name of output construction
        kdb_material_names: list of Klimatdatabas material names
        thicknesses: thickness of each material layer in metres (if opaque construction)
        mode: If opaque or aperture construction should be generated

    Returns:
        hb_materials: list of Honeybee Materials
        hb_contruction: Honeybee Construction
"""

import scriptcontext
import os
import Grasshopper

import brimstone
from brimstone import utils
ghenv.Component.Message = brimstone.globals.version

import json

ghenv.Component.Name = 'Brimstone - Honeybee Construction from Klimatdatabas materials'
ghenv.Component.NickName = 'Klimatdatabas Materials to HB'

try:  # import the core honeybee dependencies
    from honeybee_energy.material.opaque import EnergyMaterial
    from honeybee_energy.material.glazing import EnergyWindowMaterialSimpleGlazSys
    from honeybee_energy.construction.opaque import OpaqueConstruction
    from honeybee_energy.construction.window import WindowConstruction
    from honeybee.typing import clean_ep_string
except ImportError as e:
    raise ImportError('\nFailed to import honeybee:\n\t{}'.format(e))

def main(construction_name, kdb_material_names, thicknesses, mode):
    assert mode in ["opaque", "aperture"], "Mode " + mode + " is not supported"
    if mode == "opaque":
        assert len(kdb_material_names) == len(thicknesses), "Materials and thickness list must be of the same length"
    hb_materials = []
    json_data_file = brimstone.globals.kdb_hb_json_path
    json_data_file_path = os.path.join(Grasshopper.Folders.UserObjectFolders[0], json_data_file)
    if not os.path.exists(json_data_file_path):
        raise Exception("Failed to open json file, it should reside in [UserComponents folder]/brimstone_data/")
    with open(json_data_file_path, 'r') as json_file:
        json_data = json.load(json_file)
        for (i, kdb_material_name) in enumerate(kdb_material_names):
          
            try:
                mat_data = json_data[mode][kdb_material_name]
            except:
                raise Exception("Material " + kdb_material_name + " was not found in json database")
            if not mat_data["valid"]:
                utils.warn(ghenv, "Material may be faulty as the material data for " + kdb_material_name + " is invalid")
            
            # this is a bit hacky as HB can't take commas in the name
            mat_data["identifier"] = clean_ep_string(kdb_material_name)
            
            if mode == "opaque":
                mat_data["type"] = 'EnergyMaterial'
                mat_data["thickness"] = thicknesses[i]        
                hb_material = EnergyMaterial.from_dict(mat_data)
            elif mode == "aperture":
                mat_data["type"] = 'EnergyWindowMaterialSimpleGlazSys'
                hb_material = EnergyWindowMaterialSimpleGlazSys.from_dict(mat_data)
                
            hb_material.display_name = kdb_material_name
            hb_materials.append(hb_material)
    
    con_name = clean_ep_string(construction_name)
    
    if mode == "opaque":
        hb_construction = OpaqueConstruction(con_name, hb_materials)
    elif mode == "aperture":
        hb_construction = WindowConstruction(con_name, hb_materials)
    
    return hb_materials, hb_construction

if __name__ == "__main__":
    try:
        flying = scriptcontext.sticky["brimstone_flying"]
    except:
        raise Exception("The 'Brimstone - Fly' component needs to exist on the canvas")
    print construction_name
    if not construction_name:
        
        raise Exception("Construction name is missing")
    hb_materials, hb_construction = main(construction_name, kdb_material_names, thicknesses, mode)    
