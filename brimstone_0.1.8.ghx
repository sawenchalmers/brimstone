              <items count="3">
                <item name="GUID" type_name="gh_guid" type_code="9">410755b1-224a-4c1e-a407-bf32fb45ea7e</item>
                <item name="Lib" type_name="gh_guid" type_code="9">00000000-0000-0000-0000-000000000000</item>
                <item name="Name" type_name="gh_string" type_code="10">Brimstone - Modify thicknesses of Honeybee materials</item>
              </items>
              <chunks count="1">
                <chunk name="Container">
                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""
Updates thicknesses of a list of HB materials

    Args:
        hb_materials: List of Honeybee materials which should get new thickness
        thicknesses: List of new material thicknesses

    Returns:
        mod_materials: Modified Honeybee materials
"""

import scriptcontext
import brimstone
ghenv.Component.Message = brimstone.globals.version

ghenv.Component.Name = 'Brimstone - Modify thicknesses of Honeybee materials'
ghenv.Component.NickName = 'Modify layer thicknesses'

try:  # import the core honeybee dependencies
    from honeybee_energy.material.opaque import EnergyMaterial
    from honeybee_energy.material.opaque import EnergyMaterialNoMass
except ImportError as e:
    raise ImportError('\nFailed to import honeybee:\n\t{}'.format(e))

def main(hb_materials, thicknesses):
    mod_materials = []
    assert len(hb_materials) == len(thicknesses), "Materials and thickness list must be of the same length"
    for (i, material) in enumerate(hb_materials):
        if not isinstance(material, EnergyMaterial):
            if isinstance(material, EnergyMaterialNoMass):
                mod_materials.append(material)
            else:
                raise Exception("All materials must be valid Honeybee Energy Materials or Energy Materials (No Mass)")
        else: # if material is EnergyMaterial
            mod_material = material.duplicate()
            mod_material.thickness = thicknesses[i]
            mod_materials.append(mod_material)
    return mod_materials

if __name__ == "__main__":
    try:
        flying = scriptcontext.sticky["brimstone_flying"]
    except:
        raise Exception("The 'Brimstone - Fly' component needs to exist on the canvas")
    mod_materials = main(hb_materials, thicknesses)
