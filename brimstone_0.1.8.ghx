                    <item name="CodeInput" type_name="gh_string" type_code="10">"""Extracts resource names from a Klimatdatabas json object
    Inputs:
        json_data: dictionary with json data
        category: readable name of category to extract resources from
    Output:
        resources: List of resources in category"""

import scriptcontext

import brimstone
ghenv.Component.Message = brimstone.globals.version

ghenv.Component.Name = 'Brimstone - Get Resources'
ghenv.Component.NickName = 'Get Resources'

def main(json_data, category):
    resources = get_resources(json_data, category)
    return resources
    
def get_resources(json_data, category):
    pred = lambda v: v["Text"] == category
    resources = []
    for resource in json_data["Resources"]:
        if len(filter(pred, resource["Categories"])) &gt; 0:
            resources.append(resource["Name"])
    return resources

if __name__ == "__main__":
    if not scriptcontext.sticky["brimstone_flying"]:
        raise Exception("The 'Brimstone - Fly' component needs to exist on the canvas")
    resources = main(json_data, category)
    
    json_data = [json_data]

