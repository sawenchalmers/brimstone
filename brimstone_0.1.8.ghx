            <chunk name="Object" index="28">
              <items count="3">
                <item name="GUID" type_name="gh_guid" type_code="9">410755b1-224a-4c1e-a407-bf32fb45ea7e</item>
                <item name="Lib" type_name="gh_guid" type_code="9">00000000-0000-0000-0000-000000000000</item>
                <item name="Name" type_name="gh_string" type_code="10">Brimstone - Calculate Solid Geometry</item>
              </items>
              <chunks count="1">
                <chunk name="Container">
                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""Extracts LCA indicators and values from a Klimatdatabas json for a specific resource
    Inputs:
        lca_data: tree containing GWP information for the selected resource
        geometry: brep geometry
        mode: mode of GWP calculation ("typical" or "conservative")
    Output:
        gwp_total: total GWP for the selected material and geometry"""

import scriptcontext
import brimstone
reload(brimstone)
ghenv.Component.Message = brimstone.globals.version

ghenv.Component.Name = 'Brimstone - Calculate Solid Geometry'
ghenv.Component.NickName = ' Calculate Solid Geometry'

import rhinoscriptsyntax as rs
import ghpythonlib.treehelpers as th

from collections import OrderedDict

mass_inv_unit_string = 'kg' # mass
density_conv_unit_string = u'kg/m\xb3' # density
gwp_unit_string = 'kg CO2 eq./kg' # GWP

def main(lca_data, geometry, mode):
    if not lca_data.BranchCount:
        brimstone.utils.warn(ghenv, "LCA data is missing")
        return
    if not geometry:
        brimstone.utils.warn(ghenv, "Geometry is missing")
        return
    lca_data = th.tree_to_list(lca_data)
    lca_data = [OrderedDict(zip(l[0], l[1])) for l in lca_data]
    gwp_total =  []
    
    for resource_lca_data in lca_data:
        try:
            gwp_total.append(calculate_gwp_total(resource_lca_data, geometry, mode))
        except KeyError as e:
            raise Exception("GWP value could not be calculated: {error}".format(error = e))
    
    
    return gwp_total
    
def calculate_gwp_total(lca_data, geometry, mode):    
    inv_unit = lca_data["InventoryUnit"]
    conv_unit = lca_data["ConversionUnit"]
    
    if conv_unit != density_conv_unit_string or inv_unit != mass_inv_unit_string:
        raise Exception("Wrong unit for conversion from volume to mass")    
    
    gwp_unit = lca_data["GWPUnit"]
    if gwp_unit != gwp_unit_string:
        raise Exception("Wrong unit for GWP calculation")
    
    vol = rs.SurfaceVolume(geometry)[0]
    conv_value = float(lca_data["ConversionValue"])
    
    if mode == "conservative":
        gwp_a1_a3_str = "GWPA1A3Conservative"
    elif mode == "typical":
        gwp_a1_a3_str = "GWPA1A3Typical"
    else:
        raise Exception("Mode not recognised (must be conservative or typical)")
    
    gwp_impact = (
        float(lca_data[gwp_a1_a3_str])
        + float(lca_data["GWPA4"]) \
        + float(lca_data["GWPA5.1"])
    )
    
    gwp_total = (
        float(lca_data[gwp_a1_a3_str])
        + float(lca_data["GWPA4"]) \
        + float(lca_data["GWPA5.1"])
    ) * vol * conv_value
        
    return gwp_total

if __name__ == "__main__":
    if not scriptcontext.sticky["brimstone_flying"]:
        raise Exception("The 'Brimstone - Fly' component needs to exist on the canvas")   
    gwp_total = main(lca_data, geometry, mode)
    gwp_total = th.list_to_tree(gwp_total)
</item>
                    <item name="Description" type_name="gh_string" type_code="10">Extracts LCA indicators and values from a Klimatdatabas json for a specific resource</item>
                    <item name="EditorLocation" type_name="gh_drawing_point" type_code="30">
                      <X>200</X>
                      <Y>271</Y>
