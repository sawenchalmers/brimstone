              <chunks count="1">
                <chunk name="Container">
                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""Calculates operational emissions based on energy resource, EUI and floor area
    Inputs:
        lca_data: tree containing GWP information for the selected resource
        eui: energy use intensity of building in kWh/m2
        gfa: gross floor area of building
        mode: mode of GWP calculation ("typical" or "conservative")
        
    Output:
        gwp_total: total GWP for the selected space"""

import scriptcontext
import brimstone
reload(brimstone)
ghenv.Component.Message = brimstone.globals.version

ghenv.Component.Name = 'Brimstone - Calculate Operational Emissions'
ghenv.Component.NickName = 'Calculate Operational Emissions'

import rhinoscriptsyntax as rs
import ghpythonlib.treehelpers as th

from collections import OrderedDict

inv_unit_string = 'kWh'
gwp_unit_string = 'kg CO2 eq./kWh' # GWP

def main(lca_data, eui, area, mode):
    if not lca_data.BranchCount:
        brimstone.utils.warn(ghenv, "LCA data is missing")
        return
    if not eui:
        brimstone.utils.warn(ghenv, "EUI is missing")
        return
    if not area:
        brimstone.utils.warn(ghenv, "Area is missing")
        return
    
    lca_data = th.tree_to_list(lca_data)
    lca_data = [OrderedDict(zip(l[0], l[1])) for l in lca_data]
    gwp_total =  []
    
    for resource_lca_data in lca_data:
        try:
            gwp_total.append(calculate_gwp_total(resource_lca_data, eui, area, mode))
        except KeyError as e:
            raise Exception("GWP value could not be calculated: {error}".format(error = e))
    
    return gwp_total
    
def calculate_gwp_total(lca_data, eui, area, mode):    
    print lca_data
    inv_unit = lca_data["InventoryUnit"]
    
    if inv_unit != inv_unit_string:
        raise Exception("Wrong unit for calculation of operational energy")    
    
    gwp_unit = lca_data["GWPUnit"]
    if gwp_unit != gwp_unit_string:
        raise Exception("Wrong unit for GWP calculation")
    
    if mode == "conservative":
        gwp_a1_a3_str = "GWPA1A3Conservative"
    elif mode == "typical":
        gwp_a1_a3_str = "GWPA1A3Typical"
    else:
        raise Exception("Mode not recognised (must be conservative or typical)")
    
    gwp_impact = (
        float(lca_data[gwp_a1_a3_str])
    )
    
    gwp_total = (
        float(lca_data[gwp_a1_a3_str])
    ) * area * eui
        
    return gwp_total

if __name__ == "__main__":
    if not scriptcontext.sticky["brimstone_flying"]:
        raise Exception("The 'Brimstone - Fly' component needs to exist on the canvas")   
    gwp_total = main(lca_data, eui, area, mode)
    gwp_total = th.list_to_tree(gwp_total)
